---
interface Props {
  title?: string
}

const { title = 'Hollowfield' } = Astro.props
const fontsHref =
  'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;1,500&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&display=swap'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/hollowfield-favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preload" as="style" href={fontsHref} />
    <link rel="stylesheet" media="print" onload="this.media='all'" href={fontsHref} />
    <noscript>
      <link rel="stylesheet" href={fontsHref} />
    </noscript>
  </head>
  <body>
    <slot />
  </body>
</html>
