---
import cormorant500 from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-500-normal.woff2?url'
import cormorant500Italic from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-500-italic.woff2?url'
import { buildCriticalHeroCss } from '../styles/buildCriticalHeroCss.js'

interface Props {
  title?: string
}

const { title = 'Hollowfield' } = Astro.props
/** Cormorant is self-hosted; Inter + JetBrains stay on Google (below-the-fold / UI). */
const fontsHref =
  'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&display=swap'
const criticalCss = buildCriticalHeroCss(cormorant500, cormorant500Italic)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/hollowfield-favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link rel="preload" href={cormorant500} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={cormorant500Italic} as="font" type="font/woff2" crossorigin />
    <style is:inline set:html={criticalCss} />

    <link rel="stylesheet" media="print" onload="this.media='all'" href={fontsHref} />
    <noscript>
      <link rel="stylesheet" href={fontsHref} />
    </noscript>
  </head>
  <body>
    <slot />
  </body>
</html>
